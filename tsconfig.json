{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": false
  },
  "include": ["src", "scripts"]
}
