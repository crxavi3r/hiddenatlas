// HiddenAtlas — Prisma Schema
// Database: PostgreSQL (Neon)
// Prisma 7: datasource URL lives in prisma.config.ts, not here

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────
model User {
  id        String     @id @default(uuid())
  clerkId   String?    @unique   // Clerk's user_xxx ID — set on first sign-in
  email     String     @unique
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  purchases Purchase[]
  trips     Trip[]
  events    TripEvent[]
}

// ─────────────────────────────────────────────
// Itinerary
// ─────────────────────────────────────────────
model Itinerary {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  excerpt     String?
  htmlContent String?
  pdfUrl      String?
  price       Float
  coverImage  String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())

  purchases Purchase[]
}

// ─────────────────────────────────────────────
// Purchase
// ─────────────────────────────────────────────
model Purchase {
  id                    String   @id @default(uuid())
  userId                String
  itineraryId           String
  stripeSessionId       String?  @unique
  stripePaymentIntentId String?
  amount                Float
  status                String   @default("paid")
  purchasedAt           DateTime @default(now())
  createdAt             DateTime @default(now())

  user      User      @relation(fields: [userId],      references: [id])
  itinerary Itinerary @relation(fields: [itineraryId], references: [id])

  @@unique([userId, itineraryId])
}

// ─────────────────────────────────────────────
// Trip  (AI-generated, saved by user)
// ─────────────────────────────────────────────
model Trip {
  id             String    @id @default(uuid())
  userId         String
  itinerarySlug  String?   // stable slug for curated itineraries; null for AI_GENERATED
  title          String
  destination    String
  country        String    @default("")
  duration       String    @default("")
  overview       String    @default("")
  highlights     Json      @default("[]")  // String[]
  hotels         Json      @default("[]")  // { name, type, note }[]
  experiences    Json      @default("[]")  // String[]
  source         String    @default("AI_GENERATED")  // AI_GENERATED | FREE_JOURNEY | PREMIUM_JOURNEY
  createdAt      DateTime  @default(now())

  user User     @relation(fields: [userId], references: [id])
  days TripDay[]

  @@index([userId])
  // Partial unique enforced at DB level via a raw migration index (WHERE itinerarySlug IS NOT NULL)
}

// ─────────────────────────────────────────────
// TripDay  (one row per day of a saved trip)
// ─────────────────────────────────────────────
model TripDay {
  id          String @id @default(uuid())
  tripId      String
  dayNumber   Int
  title       String @default("")
  description String @default("")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

// ─────────────────────────────────────────────
// TripEvent  (immutable audit log)
// tripId is a plain String? with NO FK — rows survive trip deletion intentionally.
// eventType: SAVED | DOWNLOADED | DELETED
// ─────────────────────────────────────────────
model TripEvent {
  id        String   @id @default(uuid())
  userId    String
  tripId    String?  // no FK — preserved after trip is deleted
  eventType String   // SAVED | DOWNLOADED | DELETED
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tripId])
  @@index([eventType])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// Event  (analytics — page views, itinerary views, etc.)
// userId is nullable: anonymous events are allowed.
// country is populated from Vercel's x-vercel-ip-country header.
// ─────────────────────────────────────────────
model Event {
  id            String   @id @default(uuid())
  userId        String?
  sessionId     String?
  eventType     String
  itinerarySlug String?
  pagePath      String?
  source        String?
  country       String?
  deviceType    String?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([itinerarySlug])
  @@index([createdAt])
  @@index([sessionId])
}

// ─────────────────────────────────────────────
// CustomRequest
// ─────────────────────────────────────────────
model CustomRequest {
  id          String   @id @default(uuid())
  fullName    String
  email       String
  phone       String?
  destination String
  dates       String
  duration    String?
  groupSize   Int
  groupType   String?
  budget      String?
  style       Json     @default("[]")
  notes       String?
  status      String   @default("open")  // open | in_progress | closed
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}
