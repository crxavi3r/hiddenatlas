// HiddenAtlas — Prisma Schema
// Database: PostgreSQL (Neon)
// Prisma 7: datasource URL lives in prisma.config.ts, not here

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Creator  (influencer / guide profile)
// ─────────────────────────────────────────────
model Creator {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  avatarUrl String?
  bio       String?
  userId    String?  @unique  // FK to User.id — links to an authenticated account
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  // Instagram integration — columns are snake_case in DB (see migration 20260521000000)
  instagramAccountId      String?   @map("instagram_account_id")
  instagramAccessToken    String?   @map("instagram_access_token")
  instagramTokenExpiresAt DateTime? @map("instagram_token_expires_at")

  itineraries   Itinerary[]
  instagramLogs InstagramPublishLog[]
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────
model User {
  id        String     @id @default(uuid())
  clerkId   String?    @unique   // Clerk's user_xxx ID — set on first sign-in
  email     String     @unique
  name      String
  role      String     @default("user")  // user | admin | designer — managed via migrations
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  purchases        Purchase[]
  trips            Trip[]
  events           TripEvent[]
  pricingPlans     DesignerPricingPlan[]
  assignedRequests CustomRequest[]       @relation("AssignedDesigner")
  sharedTrips      TripShare[]           @relation("TripShareUser")
  sentInvites      TripShare[]           @relation("TripShareInvitedBy")
}

// ─────────────────────────────────────────────
// Itinerary
// ─────────────────────────────────────────────
model Itinerary {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String   // mirrors content.summary.shortDescription
  excerpt       String?
  htmlContent   String?
  pdfUrl        String?
  price         Float
  coverImage    String   // mirrors content.hero.coverImage
  isPublished   Boolean  @default(false)  // mirrors status === 'published'
  createdAt     DateTime @default(now())

  // ── CMS fields ────────────────────────────
  subtitle      String?
  destination   String?
  country       String?
  region        String?
  durationDays  Int?
  accessType    String   @default("paid")   // free | paid
  stripePriceId String?
  status        String   @default("draft")  // draft | published
  schemaVersion Int      @default(1)
  content       Json     @default("{}")     // structured editorial content (see CONTENT_SCHEMA)
  updatedAt     DateTime @default(now())    // updated via raw SQL; @updatedAt not used (raw pool)

  isCollection  Boolean  @default(false)   // true for parent/aggregate itineraries (excluded from default CMS list)
  pricingKey    String?                    // 'premium_complete' | 'premium_essential' | 'premium_short'

  type          String   @default("free")  // free | premium | custom
  isPrivate     Boolean  @default(false)   // true for custom/private itineraries
  userId        String?                    // owner for custom itineraries; null for public ones
  creatorId     String?                    // FK to Creator.id — nullable for backwards compat

  // ── PDF generation status ──────────────────
  pdfStatus       String?   // ready | generating | failed | stale
  pdfGeneratedAt  DateTime?
  pdfError        String?

  // ── Instagram publishing ────────────────────
  instagramPostId      String?
  instagramPermalink   String?
  instagramPublishedAt DateTime?

  pricingPlanId     String?                    // FK to DesignerPricingPlan.id — null for default pricing

  // ── Publication review workflow ─────────────
  // Columns added manually (migration 20260611000000).
  // status flow: draft → pending_review → published | rejected
  submittedForReviewAt  DateTime?   // when designer clicked "Submit for review"
  submittedByUserId     String?     // FK to User.id — who submitted
  reviewedAt            DateTime?   // when admin approved or rejected
  reviewedByUserId      String?     // FK to User.id — which admin reviewed
  rejectionReason       String?     // required when rejecting
  reviewMessage         String?     // optional admin note
  publishedAt           DateTime?   // set on approval

  creator           Creator?            @relation(fields: [creatorId], references: [id])
  pricingPlan       DesignerPricingPlan? @relation(fields: [pricingPlanId], references: [id])
  purchases         Purchase[]
  assets            ItineraryAsset[]
  aiGenerations     ItineraryAIGeneration[]
  customRequests    CustomRequest[]
  instagramLogs     InstagramPublishLog[]
  trips             Trip[]
  dayStops          ItineraryDayStop[]

  @@index([status])
  @@index([accessType])
  @@index([updatedAt])
  @@index([creatorId])
  @@index([submittedForReviewAt])
  @@index([reviewedAt])
  @@index([reviewedByUserId])
  @@index([status, submittedForReviewAt])
}

// ─────────────────────────────────────────────
// ItineraryDayStop  (structured per-day stops)
// ─────────────────────────────────────────────
model ItineraryDayStop {
  id                   String   @id @default(uuid())
  itineraryId          String
  dayNumber            Int
  title                String
  description          String?
  type                 String   @default("attraction")
  locationName         String?
  address              String?
  latitude             Float?
  longitude            Float?
  suggestedTime        String?
  durationMinutes      Int?
  sortOrder            Int      @default(0)
  isOptional           Boolean  @default(false)
  isMajorStop          Boolean  @default(false)
  showOnMap            Boolean  @default(true)
  bookingRecommended   Boolean  @default(false)
  bookingUrl           String?
  notes                String?
  metadata             Json     @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now())

  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
  @@index([itineraryId, dayNumber])
  @@index([itineraryId, dayNumber, sortOrder])
  @@index([showOnMap])
  @@index([type])
}

// ─────────────────────────────────────────────
// ItineraryAsset  (images per itinerary)
// assetType: hero | gallery | research | ai_suggested | manual
// source:    ai | manual
// ─────────────────────────────────────────────
model ItineraryAsset {
  id           String   @id @default(uuid())
  itineraryId  String
  assetType    String   @default("gallery")
  url          String
  alt          String?
  caption      String?
  sortOrder    Int      @default(0)
  source       String   @default("manual")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
  @@index([assetType])
}

// ─────────────────────────────────────────────
// ItineraryAIGeneration  (immutable AI draft log)
// AI output is NEVER auto-published.
// ─────────────────────────────────────────────
model ItineraryAIGeneration {
  id            String     @id @default(uuid())
  itineraryId   String?    // nullable: can generate before saving
  prompt        String
  rawOutput     String     @default("")
  parsedOutput  Json       @default("{}")
  createdBy     String?    // admin email
  createdAt     DateTime   @default(now())

  itinerary     Itinerary? @relation(fields: [itineraryId], references: [id])

  @@index([itineraryId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// Purchase
// ─────────────────────────────────────────────
model Purchase {
  id                    String   @id @default(uuid())
  userId                String?  // nullable: anonymous custom-request payments have no account
  itineraryId           String?  // nullable: custom requests before itinerary is created
  customRequestId       String?  // FK to CustomRequest.id — partial unique index in DB
  currency              String?
  stripeSessionId       String?  @unique
  stripePaymentIntentId String?
  amount                Float    // net amount charged (after discount) — kept for backward compat
  grossAmount           Float?   // full price before discount
  netAmount             Float?   // explicit net (same as amount; useful for COALESCE in queries)
  discountAmount        Float?   @default(0)
  couponCode            String?
  discountType          String?  // 'percent' | 'fixed'
  discountValue         Float?   // e.g. 20 for 20% off, or 10 for €10 off
  stripePromotionCodeId String?
  stripeCouponId        String?
  status                String   @default("paid")
  purchasedAt           DateTime @default(now())
  createdAt             DateTime @default(now())

  pricingPlanId  String?  // FK to DesignerPricingPlan.id — null for default pricing
  designerUserId String?  // Denormalized from pricingPlan.designerUserId for fast querying

  user        User?                @relation(fields: [userId],       references: [id])
  itinerary   Itinerary?           @relation(fields: [itineraryId],  references: [id])
  pricingPlan DesignerPricingPlan? @relation(fields: [pricingPlanId], references: [id])

  @@unique([userId, itineraryId])
}

// ─────────────────────────────────────────────
// Trip  (user saved trip / personal copy)
// ─────────────────────────────────────────────
model Trip {
  id             String    @id @default(uuid())
  userId         String
  itinerarySlug  String?   // stable slug for curated itineraries; null for AI_GENERATED
  itineraryId    String?   // FK to Itinerary.id — preferred link; itinerarySlug kept for compat
  title          String
  destination    String
  country        String    @default("")
  duration       String    @default("")
  overview       String    @default("")
  highlights     Json      @default("[]")  // String[]
  hotels         Json      @default("[]")  // { name, type, note }[]
  experiences    Json      @default("[]")  // String[]
  source         String    @default("AI_GENERATED")  // AI_GENERATED | FREE_JOURNEY | PREMIUM_JOURNEY
  coverImage     String?

  // ── Personal planning fields ───────────────
  subtitle             String?
  durationDays         Int?
  heroImage            String?
  startDate            DateTime?
  endDate              DateTime?
  travellers           Int?
  accommodationSummary String?
  arrivalInfo          String?
  departureInfo        String?
  generalNotes         String?
  personalPdfConfig    Json      @default("{}")
  itinerarySnapshot    Json      @default("{}")
  lastSyncedAt         DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())  // updated via raw SQL

  user      User        @relation(fields: [userId], references: [id])
  itinerary Itinerary?  @relation(fields: [itineraryId], references: [id])
  days      TripDay[]
  items     TripItem[]
  notes     TripNote[]
  bookings  TripBooking[]
  shares    TripShare[]

  @@index([userId])
  @@index([itineraryId])
  // Partial unique enforced at DB level via a raw migration index (WHERE itinerarySlug IS NOT NULL)
}

// ─────────────────────────────────────────────
// TripDay  (one row per day of a saved trip)
// ─────────────────────────────────────────────
model TripDay {
  id                  String   @id @default(uuid())
  tripId              String
  dayNumber           Int
  title               String   @default("")
  description         String   @default("")

  // ── Override & personal fields ─────────────
  sourceDayNumber     Int?
  titleOverride       String?
  descriptionOverride String?
  notes               String?   // simple day-level text note
  sortOrder           Int       @default(0)
  isHidden            Boolean   @default(false)
  resetToOriginal     Boolean   @default(false)
  updatedAt           DateTime  @default(now())  // updated via raw SQL

  trip        Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items       TripItem[]
  dayNotes    TripNote[]
  dayBookings TripBooking[]

  @@index([tripId])
}

// ─────────────────────────────────────────────
// TripItem  (custom places, restaurants, hotels, etc. added by user)
// type: place | restaurant | hotel | transfer | flight | event | note | break | itinerary_item
// status: planned | booked | done | skipped
// ─────────────────────────────────────────────
model TripItem {
  id              String   @id @default(uuid())
  tripId          String
  tripDayId       String?
  dayNumber       Int?
  sourceType      String?
  sourceKey       String?
  sourceTitle     String?
  title           String
  description     String?
  type            String   @default("place")
  locationName    String?
  address         String?
  latitude        Float?
  longitude       Float?
  startTime       String?
  endTime         String?
  durationMinutes Int?
  status          String   @default("planned")
  notes           String?
  bookingReference String?
  provider        String?
  url             String?
  isHidden        Boolean  @default(false)
  isLocked        Boolean  @default(false)
  sortOrder       Int      @default(0)
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())  // updated via raw SQL
  time            String?  // compatibility display field

  trip           Trip          @relation(fields: [tripId],    references: [id], onDelete: Cascade)
  tripDay        TripDay?      @relation(fields: [tripDayId], references: [id])
  noteRecords    TripNote[]
  bookingRecords TripBooking[]

  @@index([tripId])
  @@index([tripDayId])
}

// ─────────────────────────────────────────────
// TripNote  (general, day, item, or private notes)
// noteType: general | day | item | private
// ─────────────────────────────────────────────
model TripNote {
  id         String   @id @default(uuid())
  tripId     String
  tripDayId  String?
  tripItemId String?
  dayNumber  Int?
  title      String?
  content    String
  noteType   String   @default("general")
  isPinned   Boolean  @default(false)
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())  // updated via raw SQL

  trip     Trip      @relation(fields: [tripId],     references: [id], onDelete: Cascade)
  tripDay  TripDay?  @relation(fields: [tripDayId],  references: [id])
  tripItem TripItem? @relation(fields: [tripItemId], references: [id])

  @@index([tripId])
  @@index([tripDayId])
  @@index([tripItemId])
}

// ─────────────────────────────────────────────
// TripBooking  (hotels, flights, restaurants, etc.)
// type: hotel | restaurant | experience | transfer | flight | event | other
// ─────────────────────────────────────────────
model TripBooking {
  id                    String    @id @default(uuid())
  tripId                String
  tripDayId             String?
  tripItemId            String?
  dayNumber             Int?
  type                  String    @default("other")
  title                 String
  provider              String?
  date                  DateTime?
  time                  String?
  locationName          String?
  address               String?
  latitude              Float?
  longitude             Float?
  confirmationReference String?
  notes                 String?
  url                   String?
  attachmentUrl         String?
  status                String?
  metadata              Json      @default("{}")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now())  // updated via raw SQL

  trip     Trip      @relation(fields: [tripId],     references: [id], onDelete: Cascade)
  tripDay  TripDay?  @relation(fields: [tripDayId],  references: [id])
  tripItem TripItem? @relation(fields: [tripItemId], references: [id])

  @@index([tripId])
  @@index([tripDayId])
  @@index([tripItemId])
}

// ─────────────────────────────────────────────
// TripEvent  (immutable audit log)
// tripId is a plain String? with NO FK — rows survive trip deletion intentionally.
// eventType: SAVED | DOWNLOADED | DELETED
// ─────────────────────────────────────────────
model TripEvent {
  id        String   @id @default(uuid())
  userId    String
  tripId    String?  // no FK — preserved after trip is deleted
  eventType String   // SAVED | DOWNLOADED | DELETED
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tripId])
  @@index([eventType])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// Event  (analytics — page views, itinerary views, etc.)
// userId is nullable: anonymous events are allowed.
// country is populated from Vercel's x-vercel-ip-country header.
// ─────────────────────────────────────────────
model Event {
  id            String   @id @default(uuid())
  userId        String?
  sessionId     String?
  eventType     String
  itinerarySlug String?
  pagePath      String?
  source        String?
  country       String?
  deviceType    String?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([itinerarySlug])
  @@index([createdAt])
  @@index([sessionId])
}

// ─────────────────────────────────────────────
// CustomRequest
// ─────────────────────────────────────────────
model CustomRequest {
  id          String   @id @default(uuid())
  fullName    String
  email       String
  phone       String?
  destination String
  dates       String
  duration    String?
  groupSize   Int?     // nullable since paxMin/paxMax added; kept for backward compat
  paxMin      Int?     // lower bound of traveller range (e.g. 1 for "1–2")
  paxMax      Int?     // upper bound of traveller range (null for "13+")
  groupType   String?
  budget      String?
  style       Json     @default("[]")
  notes       String?
  status      String   @default("open")  // open | in_progress | done
  userId      String?  // internal User.id of the submitter (nullable: anonymous submissions)
  tripId      String?  // legacy Trip.id field (unused by new flows)
  itineraryId String?  // Itinerary.id — linked itinerary once created
  designerId  String?  // User.id of the assigned designer (nullable: unassigned)
  createdAt   DateTime @default(now())

  designer    User?      @relation("AssignedDesigner", fields: [designerId], references: [id])
  itinerary   Itinerary? @relation(fields: [itineraryId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([designerId])
  @@index([itineraryId])
}

// ─────────────────────────────────────────────
// DesignerPricingPlan
// Per-designer pricing — created by designers, managed in backoffice.
// planType: 'custom' | 'digital'
// ─────────────────────────────────────────────
model DesignerPricingPlan {
  id              String   @id @default(uuid())
  designerUserId  String   // FK to User.id
  name            String
  description     String?
  planType        String   @default("custom")  // custom | digital
  audienceLabel   String?                      // e.g. 'Couple', 'Family', 'Group'
  travelerMin     Int?
  travelerMax     Int?
  priceCents      Int?                         // null when isCustomQuote = true
  currency        String   @default("EUR")
  stripeProductId String?
  stripePriceId   String?
  isActive        Boolean  @default(true)
  isCustomQuote   Boolean  @default(false)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  designer    User        @relation(fields: [designerUserId], references: [id])
  purchases   Purchase[]
  itineraries Itinerary[]

  @@index([designerUserId])
  @@index([isActive])
}

// ─────────────────────────────────────────────
// InstagramPublishLog  (immutable audit log)
// Records every Instagram publish attempt.
// status: success | failed
// ─────────────────────────────────────────────
model InstagramPublishLog {
  id                  String   @id @default(uuid())
  itineraryId         String
  creatorId           String?
  instagramAccountId  String?
  instagramPostId     String?
  caption             String?
  status              String   @default("pending")
  errorMessage        String?
  instagramPermalink  String?
  publishedAt         DateTime @default(now())

  itinerary Itinerary @relation(fields: [itineraryId], references: [id])
  creator   Creator?  @relation(fields: [creatorId],   references: [id])

  @@index([itineraryId])
  @@index([creatorId])
  @@index([status])
}

// ─────────────────────────────────────────────
// TripShare  (collaborative trip sharing)
// role:   view | edit
// status: pending | accepted | revoked
// email is null for link-only invites
// userId is null until invite is accepted
// ─────────────────────────────────────────────
model TripShare {
  id              String    @id @default(dbgenerated("gen_random_uuid()"))
  tripId          String
  email           String?
  userId          String?
  role            String    @default("view")
  status          String    @default("pending")
  inviteToken     String    @unique
  invitedByUserId String
  invitedAt       DateTime  @default(now())
  acceptedAt      DateTime?
  revokedAt       DateTime?
  lastAccessedAt  DateTime?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now())

  trip      Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User? @relation("TripShareUser", fields: [userId], references: [id], onDelete: SetNull)
  invitedBy User  @relation("TripShareInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([userId])
  @@index([invitedByUserId])
  @@index([status])
  @@index([role])
}

// ─────────────────────────────────────────────
// Creator Acquisition CRM
// ─────────────────────────────────────────────

model CreatorDiscoveryRun {
  id            String    @id @default(uuid())
  name          String
  platform      String    @default("instagram")
  searchType    String    @default("manual")
  destination   String?
  country       String?
  language      String?
  hashtags      Json      @default("[]")
  bioKeywords   String?
  minFollowers  Int?
  maxFollowers  Int?
  minEngagement Float?
  category      String?
  assignedTo    String?
  status        String    @default("active")
  notes         String?
  resultCount   Int       @default(0)
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now())

  results       CreatorDiscoveryResult[]

  @@index([status])
  @@index([createdAt])
  @@index([platform])
}

model CreatorDiscoveryResult {
  id              String    @id @default(uuid())
  runId           String
  leadId          String?
  platform        String    @default("instagram")
  username        String
  profileUrl      String?
  displayName     String?
  avatarUrl       String?
  isVerified      Boolean   @default(false)
  followerCount   Int?
  postCount       Int?
  engagementRate  Float?
  bio             String?
  country         String?
  language        String?
  category        String?
  niches          Json      @default("[]")
  destinations    Json      @default("[]")
  hashtags        Json      @default("[]")
  mentions        Json      @default("[]")
  score           Float?
  routeIdeas      Json      @default("[]")
  fitSummary      String?
  status          String    @default("new")
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())

  run             CreatorDiscoveryRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  lead            CreatorLead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([leadId])
  @@index([status])
  @@index([platform, username])
}

model CreatorLead {
  id              String    @id @default(uuid())
  platform        String    @default("instagram")
  username        String
  profileUrl      String?
  displayName     String?
  firstName       String?
  avatarUrl       String?
  isVerified      Boolean   @default(false)
  email           String?
  website         String?
  bio             String?
  country         String?
  language        String?
  category        String?
  niches          Json      @default("[]")
  destinations    Json      @default("[]")
  hashtags        Json      @default("[]")
  mentions        Json      @default("[]")
  followerCount   Int?
  postCount       Int?
  engagementRate  Float?
  score           Float?
  priority        String    @default("medium")
  status          String    @default("identified")
  assignedTo      String?
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  fitSummary      String?
  routeIdeas      Json      @default("[]")
  positiveSignals Json      @default("[]")
  risks           Json      @default("[]")
  nextBestAction  String?
  sourceRunId     String?
  sourceResultId  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now())

  discoveryResults CreatorDiscoveryResult[]
  messages         CreatorLeadMessage[]
  activities       CreatorLeadActivity[]
  tasks            CreatorLeadTask[]

  @@unique([platform, username])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([nextFollowUpAt])
  @@index([country])
  @@index([language])
  @@index([createdAt])
}

model CreatorMessageTemplate {
  id          String    @id @default(uuid())
  name        String
  platform    String    @default("instagram")
  language    String    @default("pt")
  subject     String?
  body        String
  variables   Json      @default("[]")
  isActive    Boolean   @default(true)
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())

  messages    CreatorLeadMessage[]

  @@index([platform])
  @@index([language])
  @@index([isActive])
}

model CreatorLeadMessage {
  id                String    @id @default(uuid())
  leadId            String
  templateId        String?
  platform          String    @default("instagram")
  subject           String?
  body              String
  personalizedBody  String?
  status            String    @default("draft")
  copiedAt          DateTime?
  sentAt            DateTime?
  sentBy            String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now())

  lead              CreatorLead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  template          CreatorMessageTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([templateId])
  @@index([status])
}

model CreatorLeadActivity {
  id          String    @id @default(uuid())
  leadId      String
  type        String
  content     String?
  metadata    Json      @default("{}")
  createdBy   String?
  createdAt   DateTime  @default(now())

  lead        CreatorLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([type])
  @@index([createdAt])
}

model CreatorLeadTask {
  id            String    @id @default(uuid())
  leadId        String
  title         String
  description   String?
  dueAt         DateTime?
  completedAt   DateTime?
  snoozedUntil  DateTime?
  status        String    @default("pending")
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now())

  lead          CreatorLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([status])
  @@index([dueAt])
}
