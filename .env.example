# Clerk — get from https://dashboard.clerk.com → API Keys
# REQUIRED: app will show config error screen without this
VITE_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Backend API — set to your deployed backend URL in production
# Leave blank or omit locally (defaults to http://localhost:4000)
VITE_API_URL=https://your-backend.railway.app

# Itinerary pricing tiers — Stripe Dashboard → Products → [product] → Prices → copy Price ID
# Leave a tier blank to hide it from the CMS dropdown
STRIPE_PRICE_PREMIUM_SHORT=price_xxxxxxxxxxxxxxxxxxxxx       # €14 — Premium Itinerary Short
STRIPE_PRICE_PREMIUM_ESSENTIAL=price_xxxxxxxxxxxxxxxxxxxxx   # €19 — Premium Itinerary Essential
STRIPE_PRICE_PREMIUM_COMPLETE=price_xxxxxxxxxxxxxxxxxxxxx    # €29 — Premium Itinerary Complete
